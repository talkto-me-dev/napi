  "optionalDependencies": {
    "@3-/captcha-darwin-arm64": "0.1.46",
    "@3-/captcha-darwin-x64": "0.1.46",
    "@3-/captcha-linux-arm64-gnu": "0.1.46",
    "@3-/captcha-linux-arm64-musl": "0.1.46",
    "@3-/captcha-linux-x64-gnu": "0.1.46",
